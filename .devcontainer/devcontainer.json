{
    "name": "Python, C++, LaTeX",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/python:1": {}
        // 已移除 texlive feature
    },
    // 在 postCreateCommand 中通过 apt 安装 LaTeX 基础版和 C++ 工具
    "postCreateCommand": "sudo apt update && sudo apt install -y g++ gdb make cmake texlive-base texlive-latex-recommended",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "james-yu.latex-workshop"
            ]
        }
    },
    "remoteUser": "vscode"
}
